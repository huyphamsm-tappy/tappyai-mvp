# ── Brevo SMTP (transactional email — src/lib/email/EmailService.ts) ────────
# Get these from Brevo: Settings -> SMTP & API -> SMTP tab.
# All 6 are required; missing any one causes EmailService to reject sending
# (fails gracefully, returns { success: false } — never throws).

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=TappyAI

# Optional. Recipient inbox for internal notification emails (contact/investor/
# Google for Startups form submissions). Falls back to EMAIL_FROM when unset.
TEAM_EMAIL=
