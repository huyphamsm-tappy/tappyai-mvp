{
  "headers": [
    {
      "source": "/games/supertux/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/lunch-reminder",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/travel-reminder",
      "schedule": "0 2 * * *"
    }
  ]
}
