<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme — content is rendered entirely in Compose (core:designsystem Theme.kt).
         This XML theme only controls the pre-Compose window background/splash. -->
    <style name="Theme.TappyAI" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
