# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# App URL (dùng cho Supabase redirect)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Travelpayouts / Aviasales — dùng cho tính năng tra giá vé máy bay
# Lấy token tại: https://www.travelpayouts.com/developers/api (đăng nhập → API → Token)
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token_here

# Apple In-App Purchase (App Store Server API + Notifications V2)
# Required before enabling SHOW_PRO_UPGRADE.
# App Store Connect → Users and Access → Integrations → In-App Purchase
APPLE_IAP_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APPLE_IAP_KEY_ID=XXXXXXXXXX
# Paste the full .p8 private key content; escape newlines as \n for Vercel env vars
APPLE_IAP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----
APPLE_IAP_BUNDLE_ID=com.tappyai.ios
# "Sandbox" during development/TestFlight, "Production" in the App Store
APPLE_IAP_ENV=Production
# Download AppleRootCA-G3.cer from https://www.apple.com/certificateauthority/
# Convert to PEM: openssl x509 -inform DER -in AppleRootCA-G3.cer -out AppleRootCA-G3.pem
# Then paste contents here (escape newlines as \n)
APPLE_ROOT_CA_PEM=-----BEGIN CERTIFICATE-----\nMIIC...\n-----END CERTIFICATE-----
